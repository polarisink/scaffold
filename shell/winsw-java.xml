<service>
    <id>yfs</id>
    <name>YFS Service</name>
    <description>YFS Spring Boot Application</description>

    <executable>C:\Program Files\Java\jdk1.8.0_381\bin\java.exe</executable>
    <arguments>-jar yfs-admin.jar --spring.profiles.active=test --spring.config.location=file:config/</arguments>
    <workingdirectory>D:\yfs</workingdirectory>

    <logpath>D:\yfs\logs</logpath>
    <log mode="roll-by-size">
        <sizeThreshold>10485760</sizeThreshold>
        <keepFiles>10</keepFiles>
    </log>

    <startmode>Automatic</startmode>
    <onfailure action="restart" delay="10 sec"/>
</service>

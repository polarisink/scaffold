NACOS_VERSION=v3.1.2-slim
NACOS_SERVER_PORT=8848
NACOS_CONSOLE_PORT=8080
NACOS_GRPC_PORT=9848
NACOS_USERNAME=nacos
NACOS_PASSWORD=123456
NACOS_AUTH_ENABLE=false
CLOUD_NETWORK=scaffold-cloud

# Cloud 服务在容器中通过宿主机 MySQL 访问三个独立业务库。
BUSINESS_DATASOURCE_USERNAME=root
BUSINESS_DATASOURCE_PASSWORD=123456
PROVIDER_DATASOURCE_URL=jdbc:mysql://host.docker.internal:3306/scaffold_provider?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
CONSUMER_DATASOURCE_URL=jdbc:mysql://host.docker.internal:3306/scaffold_consumer?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
ORDER_DATASOURCE_URL=jdbc:mysql://host.docker.internal:3306/scaffold_order?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true

# 仅 compose.mysql.yml 启用以下 MySQL 配置。
NACOS_MYSQL_PORT=3306
NACOS_MYSQL_DATABASE=nacos_devtest
NACOS_MYSQL_USER=nacos
NACOS_MYSQL_PASSWORD=nacos
NACOS_MYSQL_ROOT_PASSWORD=root

SEATA_PORT=8091
SENTINEL_PORT=8858
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
